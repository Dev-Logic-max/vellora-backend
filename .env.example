# ─────────────────────────────────────────────────────────────
# Vellora API — environment variables (names only; real values
# live in .env which is gitignored). Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# PostgreSQL connection (Supabase-compatible pooled connection string).
# Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vellora

# Supabase project credentials (used to validate end-user JWTs)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy/JWT secret used to verify HS256 access tokens (Supabase: API → JWT Secret)
SUPABASE_JWT_SECRET=
