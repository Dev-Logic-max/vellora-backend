# Vellora API — environment variables (names only; real values live in .env,
# which is gitignored). Copy this file to .env and fill in.

# Runtime
NODE_ENV=development
PORT=3030

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Postgres — migrations use the DIRECT/session connection, runtime uses the
# transaction-mode pooler (6543). Get both from Supabase → Connect → Drizzle.
# URL-encode special chars in the password (e.g. @ becomes %40).
DATABASE_URL=          # session/direct (5432) — drizzle-kit migrations
DATABASE_POOL_URL=     # transaction pooler (6543) — app runtime

# Supabase project (validate end-user JWTs)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=    # Supabase → Settings → API → JWT Secret (HS256)

# Cloudinary — file/image uploads (logos, avatars)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Upstash Redis — BullMQ queues (Phase 2)
REDIS_URL=             # rediss:// TCP URL

# Email — transactional mail (Phase 7)
RESEND_API_KEY=

# Stripe — billing (Phase 8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Gemini — AI features (Phase 9)
GEMINI_API_KEY=

# Seeds (npm run db:seed). SEED_ENABLED must be true or the runner refuses to run.
# SEED_FILE picks which seed (basic | reset); a CLI arg overrides it: `npm run db:seed -- reset`.
# SEED_PASSWORD overrides the default password for seeded role logins.
SEED_ENABLED=false
SEED_FILE=basic
SEED_PASSWORD=
