{
  "compilerOptions": {
    // `commonjs` + `node10` is the ONLY working module mode for this stack:
    // Nest runs the emitted JS directly in Node (needs CommonJS output), and
    // Drizzle's types break under "nodenext"/"node16" (dual import/require
    // resolution → two incompatible `SQL` types) while "bundler" forces ESM
    // emit. So we keep node10 + silence the TS-7.0 deprecation with
    // `ignoreDeprecations: "5.0"` (the value our toolchain TS 5.9.3 accepts).
    // NOTE: an editor bundling TS 6.0 may still show a cosmetic "node10
    // deprecated" notice in its Problems panel — `tsc` + `nest build` are clean;
    // it has no effect on compilation/runtime. Revisit at TS 7.0. baseUrl is
    // removed (no path aliases → not needed).
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "ES2023",
    "lib": ["ES2023"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
